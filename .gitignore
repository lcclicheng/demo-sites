# 依赖（每个 output 站点会在构建时独立 npm install）
node_modules/

# 构建产物（由 generate.mjs 生成，不纳入版本管理）
output/
dist/
public/

# 构建日志
build-logs/
*.log
gen8*.log
# 例外：项目变动历史（与 state/ 配对，需进版本控制便于 diff/排查）
!events.log

# 系统文件
.DS_Store
Thumbs.db

# 旧的根级站点目录（已被 Actions 部署的 public/ 取代，仅本地残留，不纳入版本管理）
/atelier/
/creme/
/breath/
/chambers/
/forge/
/mario/
/mono/
/patisserie/
/sotto-sotto/
/vault/

# 客户反馈知识库（含敏感信息，不进仓库）
# 用 clients/** 忽略全部内容但保留目录可遍历，从而可单独放行约定文档
clients/**
# CRM 约定文档入库（真实客户数据：合同/发票/反馈/info 仍私有）
!clients/README.md

# 外联 CRM 系统（含 30 家真实商家邮箱/外联状态/策略，整目录不进公开仓库；参照 clients/** 范式）
outreach/

# Lead Memory（长期线索资产，含真实商家邮箱/GBP 数据；实例化目录不进公开仓库，_template/与脚本作为系统骨架入库）
lead/*
!lead/_template/
!lead/_template/**
!lead/README.md
!lead/init-lead.mjs

# Business Operating System（含定价/KPI/CRM 内部口径与运营节奏，不进公开仓库）
business/

# 客户交付模板工具包（合同/提案/隐私政策/获客话术/定价模板，随 business/ 同规则不进公开仓库）
business-kit/
